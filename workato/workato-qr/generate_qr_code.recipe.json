        "provider": "py_eval",
        "name": "invoke_custom_py_code",
        "skip": false,
        "comment": "Generate QR code via api.qrserver.com, return base64 PNG",
        "uuid": "caded422-a207-4b83-9699-63809005a2f8",
        "input": {
          "name": "Generate QR code",
          "code": "import urllib.request\nimport urllib.parse\nimport base64\n\ndef main(input):\n    url = (input.get('url') or '').strip()\n    if not url:\n        raise ValueError('url is required')\n    color = (input.get('color') or '000000').lstrip('#').strip() or '000000'\n    size = 300\n    api_url = (\n        'https://api.qrserver.com/v1/create-qr-code/'\n        '?size=' + str(size) + 'x' + str(size) +\n        '&data=' + urllib.parse.quote(url, safe='') +\n        '&color=' + color +\n        '&bgcolor=ffffff&format=png&margin=10&qzone=1'\n    )\n    req = urllib.request.Request(api_url, headers={'User-Agent': 'Workato-QR/1.0'})\n    with urllib.request.urlopen(req, timeout=15) as resp:\n        png_bytes = resp.read()\n    return {\n        'image_base64': base64.b64encode(png_bytes).decode('ascii'),\n        'mime_type': 'image/png',\n        'width': size,\n        'height': size,\n        'url': url\n    }\n",
          "code_input": {
            "schema": "[{\"name\": \"url\", \"type\": \"string\", \"label\": \"URL\", \"control_type\": \"text\", \"optional\": false}, {\"name\": \"color\", \"type\": \"string\", \"label\": \"Color\", \"control_type\": \"text\", \"optional\": true}]",
            "data": {
              "url": "#{_dp('{\"pill_type\": \"output\", \"provider\": \"workato_skill\", \"line\": \"qr_trigger_109f3258\", \"path\": [\"parameters\", \"url\"]}')}",
