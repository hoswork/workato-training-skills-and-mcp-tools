      "result_schema_json": "[{\"name\": \"valid\", \"type\": \"string\", \"label\": \"Valid (true/false)\", \"control_type\": \"text\"}, {\"name\": \"file_base64\", \"type\": \"string\", \"label\": \"XLSX file (base64)\", \"control_type\": \"text\"}, {\"name\": \"mime_type\", \"type\": \"string\", \"label\": \"MIME type\", \"control_type\": \"text\"}, {\"name\": \"filename\", \"type\": \"string\", \"label\": \"Filename\", \"control_type\": \"text\"}, {\"name\": \"errors\", \"type\": \"string\", \"label\": \"Validation errors (JSON)\", \"control_type\": \"text\"}]"
    },
